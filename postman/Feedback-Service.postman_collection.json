			"item": [
				{
					"name": "Submit Feedback",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"var jsonData = pm.response.json();",
									"if(jsonData.feedbackId) {",
									"    pm.environment.set(\"feedbackId\", jsonData.feedbackId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"userId\": {{userId}},\n  \"serviceRequestId\": {{bookingId}},\n  \"rating\": 5,\n  \"comments\": \"Excellent service! Technician was punctual and completed the work cleanly.\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/feedback",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"feedback"
							]
						}
					},
					"response": []
