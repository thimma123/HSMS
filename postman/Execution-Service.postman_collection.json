{
	"info": {
		"_postman_id": "dd47bbcc-4b40-4fdf-b8f4-6a56e0766def",
		"name": "Execution-Service",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "ServiceRecordController",
			"item": [
				{
					"name": "Start Service",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"var jsonData = pm.response.json();",
									"if(jsonData.recordId) {",
									"    pm.environment.set(\"executionId\", jsonData.recordId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"serviceRequestId\": {{bookingId}}\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/records/start",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"records",
								"start"
							]
						}
					},
					"response": []
				},
				{
					"name": "Complete Service",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"remarks\": \"Replaced the main flush valve, resolved leak\",\n  \"actualCost\": 450.0,\n  \"paymentMethod\": \"UPI\",\n  \"technicianNotes\": \"Tap handles are slightly worn out, might need replacement soon\",\n  \"executionNotes\": \"Repair took 1.5 hours using high grade replacement kit\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/records/complete/{{executionId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"records",
								"complete",
								"{{executionId}}"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Service Record",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/records/{{executionId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"records",
								"{{executionId}}"
							]
						}
					},
					"response": []
				}
			]
		}
	]
}
